{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchIgnore": [
      "hackathon/**",
      "*.md"
    ],
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "nodejs_22"
          ]
        },
        "install": {
          "cmds": [
            "cd server && npm install"
          ]
        },
        "build": {
          "cmds": []
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd server && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
